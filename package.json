{
  "name": "studypath",
  "productName": "StudyPath",
  "description": "Desktop companion app for a 15-month technical study roadmap.",
  "author": {
    "name": "Ryan Eloy"
  },
  "private": true,
  "license": "MIT",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist-electron/main/main.js",
  "scripts": {
    "dev": "concurrently -k -n server,vite -c blue,green \"npm:dev:server\" \"npm:dev:vite\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:vite": "vite",
    "dev:electron": "electron-vite dev",
    "rebuild:node": "npm rebuild better-sqlite3",
    "rebuild:electron": "electron-rebuild -f -w better-sqlite3",
    "icon:generate": "node scripts/generate-icon.mjs",
    "build:renderer": "tsc -b && vite build",
    "build:electron": "electron-vite build",
    "build": "npm run build:renderer",
    "pack:mac": "npm run build:electron && electron-builder --mac",
    "pack:win": "npm run build:electron && electron-builder --win",
    "pack:linux": "npm run build:electron && electron-builder --linux",
    "pack": "npm run build:electron && electron-builder",
    "lint": "eslint .",
    "preview": "vite preview",
    "smoke": "node scripts/smoke.mjs",
    "smoke:api": "node scripts/smoke-api.mjs",
    "smoke:persistence": "node scripts/smoke-persistence.mjs"
  },
  "dependencies": {
    "@blocknote/core": "^0.47.3",
    "@blocknote/mantine": "^0.47.3",
    "@blocknote/react": "^0.47.3",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@emoji-mart/data": "^1.2.1",
    "@emoji-mart/react": "^1.1.1",
    "@fontsource/instrument-serif": "^5.2.8",
    "@fontsource/inter": "^5.2.8",
    "@hono/node-server": "^1.19.14",
    "@mantine/core": "^8.3.18",
    "@mantine/hooks": "^8.3.18",
    "@phosphor-icons/react": "^2.1.10",
    "better-sqlite3": "^12.9.0",
    "docx": "^9.6.1",
    "electron-updater": "^6.8.3",
    "emoji-mart": "^5.6.0",
    "hono": "^4.12.12",
    "i18next": "^26.0.4",
    "mammoth": "^1.12.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^17.0.3",
    "react-router-dom": "^7.14.0",
    "shiki": "^4.0.2",
    "simple-icons": "^16.16.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.2.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "playwright": "^1.59.1",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4"
  }
}
